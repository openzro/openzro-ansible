---
# Lab group_vars — copy this file to `all.yml` and fill in the values
# below. `all.yml` is gitignored; `all.yml.example` is committed as a
# template.

# ---------------------------------------------------------------------
# Public-facing domain. Clients dial management/signal at this name and
# trust the TLS cert presented for it. For lab use a wildcard A record
# pointing at this single host (e.g. openzro.example.com → 192.168.1.10).
# ---------------------------------------------------------------------
openzro_public_domain: "openzro.example.com"

# Public hostname for the relay (peers connect here directly, not
# through the dashboard's reverse proxy). Often the same as the
# public domain, sometimes a separate `relay.<domain>`.
openzro_relay_public_address: "{{ openzro_public_domain }}"
openzro_relay_port: 33080

# ---------------------------------------------------------------------
# OIDC / Identity provider. Lab default: Dex on the same host (managed
# separately via docker / a sister role, not this playbook). For real
# deployments point at Keycloak, Auth0, Authentik, etc.
# ---------------------------------------------------------------------
openzro_oidc_issuer: "https://dex.{{ openzro_public_domain }}"
openzro_oidc_client_id: "openzro-dashboard"
openzro_oidc_client_secret: "REPLACE_WITH_DEX_OR_KEYCLOAK_SECRET"
# JSON array, comma-separated values supported by management's
# config validator. Must include `email` for user identity.
openzro_oidc_supported_scopes: "openid profile email groups"

# ---------------------------------------------------------------------
# Datastore. SQLite is fine for a lab; Postgres is required for HA.
# ---------------------------------------------------------------------
openzro_datastore_engine: "sqlite"   # sqlite | postgres
# Postgres DSN — only used when engine == postgres.
# openzro_postgres_dsn: "host=db.internal port=5432 user=openzro password=REPLACE dbname=openzro sslmode=require"

# ---------------------------------------------------------------------
# Auth shared secret for the relay (peers present this to register).
# Generate once with:
#   openssl rand -base64 32
# Treat as a credential — vault-encrypt this in real inventories.
# ---------------------------------------------------------------------
openzro_relay_auth_secret: "REPLACE_WITH_BASE64_RANDOM_32B"

# ---------------------------------------------------------------------
# TLS / cert handling. The openzro_nginx role implements four modes:
#
#   certbot_http  — Let's Encrypt via HTTP-01 (default for prod).
#                   Host must be reachable on port 80. Auto-renews
#                   via the certbot.timer systemd unit.
#   certbot_dns   — Let's Encrypt via DNS-01 (Cloudflare today).
#                   Works behind a firewall, supports wildcard.
#                   Set openzro_tls_cloudflare_api_token below.
#   byo           — Bring your own cert files from the control host.
#   self_signed   — Generate a self-signed cert (LAB ONLY).
# ---------------------------------------------------------------------
openzro_tls_mode: self_signed   # lab default — switch to certbot_http for prod

# certbot_http / certbot_dns
# openzro_tls_email: admin@example.com

# certbot_dns — Cloudflare API token (vault-encrypt this)
# openzro_tls_cloudflare_api_token: !vault | $ANSIBLE_VAULT;1.1;AES256...

# byo — paths on the CONTROL host (Ansible reads + pushes contents)
# openzro_tls_cert_path: /etc/letsencrypt/live/example.com/fullchain.pem
# openzro_tls_key_path:  /etc/letsencrypt/live/example.com/privkey.pem

# ---------------------------------------------------------------------
# Cloud LB — only relevant when running this playbook against a host
# in AWS or GCP. Set to "none" for bare-metal / VPS / on-prem.
# ---------------------------------------------------------------------
openzro_cloud: none   # none | aws | gcp

# ---------------------------------------------------------------------
# Operational tuning — usually leave at defaults.
# ---------------------------------------------------------------------
openzro_log_level: "info"   # trace | debug | info | warn | error

# Pin a specific release (without the "v" prefix). Leave unset to
# install whatever apt/dnf considers the latest in the openzro repo.
# openzro_version: "0.53.1-alpha.9"
