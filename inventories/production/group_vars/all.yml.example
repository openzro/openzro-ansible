---
# Production group_vars template. Copy to `all.yml`, fill in, encrypt
# the secrets with ansible-vault, and never commit `all.yml`.

openzro_public_domain: "openzro.example.com"
openzro_relay_public_address: "relay.{{ openzro_public_domain }}"
openzro_relay_port: 33080

openzro_oidc_issuer: "https://auth.example.com/realms/openzro"
openzro_oidc_client_id: "openzro-dashboard"
openzro_oidc_client_secret: !vault |
  $ANSIBLE_VAULT;1.1;AES256
  REPLACE_WITH_VAULTED_SECRET
openzro_oidc_supported_scopes: "openid profile email groups"

# Postgres is mandatory for HA — sqlite is single-process only.
openzro_datastore_engine: postgres
openzro_postgres_dsn: !vault |
  $ANSIBLE_VAULT;1.1;AES256
  REPLACE_WITH_VAULTED_DSN

openzro_relay_auth_secret: !vault |
  $ANSIBLE_VAULT;1.1;AES256
  REPLACE_WITH_VAULTED_RANDOM_32B

# Production TLS — let certbot manage the cert + auto-renewal.
openzro_tls_mode: certbot_http
openzro_tls_email: admin@example.com

# Or — DNS-01 (wildcard / behind firewall):
# openzro_tls_mode: certbot_dns
# openzro_tls_cloudflare_api_token: !vault |
#   $ANSIBLE_VAULT;1.1;AES256
#   REPLACE_WITH_VAULTED_TOKEN

# Cloud LB — pick the cloud the prod host runs on.
openzro_cloud: aws   # or gcp

openzro_log_level: "info"
openzro_version: "0.53.1-alpha.9"

# ── Routing peers ─────────────────────────────────────────────
# A single setup key shared by every host in the `routing_peer`
# group is the simplest model: the management knows the group
# attached to the key, and Network Resources hang off that group.
# Use a per-region key when you want region-specific CIDRs.
#
# Override per-host via host_vars/<host>.yml when one box should
# attract a different subnet pool than its sibling.
openzro_management_url: "https://{{ openzro_public_domain }}"
openzro_routing_peer_setup_key: !vault |
  $ANSIBLE_VAULT;1.1;AES256
  REPLACE_WITH_VAULTED_REUSABLE_SETUP_KEY
