# {{ ansible_managed }}
OPENZRO_LOG_LEVEL={{ openzro_log_level | default('info') }}
{% if openzro_management_datastore_engine == "postgres" %}
OPENZRO_DATASTORE_ENC_KEY={{ openzro_management_datastore_key }}
{% endif %}

# Cluster coordinator — required when there's more than one
# `management` host in the inventory. Each management process boots
# an embedded NATS+JetStream server (no external broker), and the
# instances gossip between themselves on tcp/6222. Single-replica
# deployments leave openzro_cluster_backend at "none" (default) —
# the coordinator stays nil and management runs in single-instance
# mode (datastore is the only state).
{% if openzro_cluster_backend == "embedded" %}
OPENZRO_BROKER=embedded
OPENZRO_EMBEDDED_NATS_JETSTREAM_DIR={{ openzro_management_data_dir }}/jetstream
{% if openzro_cluster_peers | length > 0 %}
OPENZRO_CLUSTER_PEERS={{ openzro_cluster_peers | join(',') }}
{% endif %}
{% elif openzro_cluster_backend == "nats" %}
OPENZRO_NATS_URL={{ openzro_cluster_nats_url }}
{% elif openzro_cluster_backend == "redis" %}
OPENZRO_REDIS_URL={{ openzro_cluster_redis_url }}
{% endif %}
