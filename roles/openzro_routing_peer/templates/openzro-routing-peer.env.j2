{# Rendered by openzro-ansible — do not edit by hand. #}
# Daemon-level config for the openzro client running as a routing
# peer. The actual login (setup key, management URL) is handled by
# `openzro up` in the role tasks; this file holds the few values
# that influence the daemon at process start.
OPENZRO_LOG_LEVEL={{ openzro_log_level | default('info') }}
{% if openzro_management_url is defined %}
OZ_MANAGEMENT_URL={{ openzro_management_url }}
{% endif %}
